{
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Port=5432;Database=lighthouse_sanctuary;Username=postgres;Password=REPLACE_WITH_LOCAL_SECRET;Include Error Detail=true"
  },
  "DatabaseBootstrap": {
    "SchemaFile": "../schema_postgres_supabase.sql",
    "SeedFile": "../seed_sample_data.sql",
    "SeedMode": "IfEmpty"
  },
  "Jwt": {
    "Issuer": "Lighthouse.Sanctuary.Api",
    "Audience": "Lighthouse.Frontend",
    "Key": "ReplaceThisForProductionWithALongSecureJwtSigningKey123!",
    "TokenLifetimeMinutes": 120
  },
  "AuthSeed": {
    "Enabled": false,
    "Users": []
  },
  "MlRuntime": {
    "FunctionAppUrl": "http://localhost:7071",
    "FunctionKey": "",
    "TimeoutMs": 180000,
    "DbProfile": "local"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
